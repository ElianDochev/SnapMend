{
  "name": "snapmend",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "api",
    "client"
  ],
  "scripts": {
    "build": "bun run --filter api build && bun run --filter client build",
    "dev": "bun run --filter api dev",
    "lint": "bun run --filter api lint && bun run --filter client lint",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "real-test": "bun run --cwd api real-test",
    "test": "bun run --filter api test",
    "test:watch": "bun run --filter api test:watch"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.26.1"
  }
}
