{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "module": "commonjs",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "isolatedModules": true,
    "types": ["node", "jest", "express", "multer"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "jest.config.ts"]
}
